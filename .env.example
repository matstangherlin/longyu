# Longyu — variáveis de ambiente (copie para .env.local)

# ─── Ambientes ───────────────────────────────────────────────────────────────
# Development     → npm run dev (import.meta.env.DEV)
# Preview         → Deploy Preview Netlify (VITE_APP_ENV=preview)
# Production Beta → site principal (VITE_APP_ENV=production_beta)
#
# Regras:
# - VITE_ALLOW_PRO_PREVIEW nunca true em Production Beta
# - VITE_USE_TEST_FIXTURES nunca true em Production Beta
# - Variáveis de Preview não devem ser copiadas para o contexto production

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────

# Modo de backend: "local" (padrão) ou "supabase"
VITE_BACKEND_MODE=local

# Ambiente lógico do build (opcional em dev; obrigatório nos deploys Netlify)
# VITE_APP_ENV=development
# VITE_APP_ENV=preview
# VITE_APP_ENV=production_beta

# Supabase — somente URL + chave anon/publishable (nunca service_role no front)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Painel admin de feedback (e-mails separados por vírgula; além de teste@/admin@longyu.app)
VITE_ADMIN_EMAILS=

# Versão exibida na UI e no feedback técnico
VITE_APP_VERSION=0.2.0-beta.1

# Pro Preview local (só Development ou Preview). Bloqueado em Production Beta.
# VITE_ALLOW_PRO_PREVIEW=true

# Fixtures de teste (nunca em Production Beta)
# VITE_USE_TEST_FIXTURES=true

# Feature flags de rollback (default: ligados)
# VITE_ENABLE_CONVERSATION_V2=false
# VITE_ENABLE_TELEMETRY=false
# VITE_ENABLE_BETA_FEEDBACK=false

# ─── Supabase CLI / deploy (somente local, nunca commitar) ───────────────────
# Gere em https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
# Para deploy automático via GitHub Actions, adicione o mesmo token em:
#   Repo → Settings → Secrets and variables → Actions → SUPABASE_ACCESS_TOKEN
# Depois: Actions → Deploy Leagues → Run workflow
# SUPABASE_PROJECT_REF=drjcfalvlbbeblmmyhwj
#
# Netlify (opcional — para npm run configure:netlify automatizar env + rebuild)
# Gere em https://app.netlify.com/user/applications#personal-access-tokens
# NETLIFY_AUTH_TOKEN=nfp_...
# NETLIFY_SITE_NAME=singular-meringue-7838cd
# NETLIFY_SITE_ID=
# LONGYU_PROD_URL=https://singular-meringue-7838cd.netlify.app
# Senha do banco (alternativa ao token): Settings → Database → Reset password
# SUPABASE_DB_PASSWORD=
# Nunca commitar estes valores. Configure com:
#   supabase secrets set STRIPE_SECRET_KEY=sk_... STRIPE_WEBHOOK_SECRET=whsec_...
#
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Netlify (Site settings → Environment variables) ─────────────────────────
# Production (contexto production):
#   VITE_APP_ENV=production_beta
#   VITE_APP_VERSION=0.2.0-beta.1
#   VITE_BACKEND_MODE=supabase
#   VITE_SUPABASE_URL=https://<project-ref>.supabase.co
#   VITE_SUPABASE_ANON_KEY=<anon-key>
#   VITE_ALLOW_PRO_PREVIEW=false
#   VITE_USE_TEST_FIXTURES=false
#
# Deploy Preview (contexto deploy-preview):
#   VITE_APP_ENV=preview
#   (mesmas chaves anon; sem Pro Preview / fixtures)
#
# Depois do deploy, adicione a URL do site nos redirects do Supabase Auth:
#   LONGYU_PROD_URL=https://seu-site.netlify.app
#   npm run configure:supabase-auth -- --add-prod-url https://seu-site.netlify.app
#
# Build: npm run build  |  Publish: dist/
